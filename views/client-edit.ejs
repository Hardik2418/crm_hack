<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Request</title>
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <div class="dashboard-layout">
    <aside class="sidebar">
      <a href="/client/dashboard" class="sidebar-logo">ResolveX</a>
      <nav class="sidebar-nav">
        <a href="/client/dashboard" class="sidebar-link">My Requests</a>
        <a href="/client/create" class="sidebar-link">Create Request</a>
        <a href="/notifications" class="sidebar-link">Notifications</a>
      </nav>
    </aside>

    <div class="dashboard-main">
      <header class="top-navbar">
        <div class="top-navbar-left">
          <h1>Edit Request</h1>
        </div>
        <div class="top-navbar-right">
          <a href="/client/dashboard">Back to My Requests</a>
          <a href="/logout">Logout</a>
        </div>
      </header>

      <main>
        <section class="create-form-wrapper">
          <div class="create-form-card">
            <h2>Update request</h2>
            <p class="create-form-subtitle">Modify the details of your request. Order ID cannot be changed.</p>

            <form class="create-form" method="POST" action="/client/<%= request._id %>/edit">
              <div class="form-row">
                <div class="form-field">
                  <label>Order ID</label>
                  <input type="text" value="<%= request.orderId || request.id %>" disabled>
                </div>
              </div>

              <div class="form-row">
                <div class="form-field">
                  <label for="type">Type</label>
                  <select id="type" name="type" required>
                    <option value="Ticket" <%= request.type === 'Ticket' ? 'selected' : '' %>>Ticket</option>
                    <option value="Issue" <%= request.type === 'Issue' ? 'selected' : '' %>>Issue</option>
                    <option value="Bug" <%= request.type === 'Bug' ? 'selected' : '' %>>Bug</option>
                  </select>
                </div>
                <div class="form-field">
                  <label for="tag">Tag</label>
                  <select id="tag" name="tag" required>
                    <option value="Feature" <%= request.tag === 'Feature' ? 'selected' : '' %>>Feature</option>
                    <option value="Fix" <%= request.tag === 'Fix' ? 'selected' : '' %>>Fix</option>
                    <option value="UI" <%= request.tag === 'UI' ? 'selected' : '' %>>UI</option>
                    <option value="Urgent" <%= request.tag === 'Urgent' ? 'selected' : '' %>>Urgent</option>
                    <option value="Danger" <%= request.tag === 'Danger' ? 'selected' : '' %>>Danger</option>
                  </select>
                </div>
              </div>

              <div class="form-row">
                <div class="form-field">
                  <label for="customerName">Customer Name</label>
                  <input type="text" id="customerName" name="customerName" value="<%= request.customerName || '' %>">
                </div>
                <div class="form-field">
                  <label for="name">Title / Short Name</label>
                  <input type="text" id="name" name="name" value="<%= request.name %>" required>
                </div>
              </div>

              <div class="form-row">
                <div class="form-field">
                  <label for="customerEmail">Customer Email</label>
                  <input type="email" id="customerEmail" name="customerEmail" value="<%= request.customerEmail || '' %>">
                </div>
                <div class="form-field">
                  <label for="customerPhone">Customer Phone</label>
                  <input type="tel" id="customerPhone" name="customerPhone" value="<%= request.customerPhone || '' %>">
                </div>
              </div>

              <div class="form-row">
                <div class="form-field">
                  <label for="product">Product</label>
                  <input type="text" id="product" name="product" value="<%= request.product || '' %>">
                </div>
                <div class="form-field">
                  <label for="city">City</label>
                  <input type="text" id="city" name="city" value="<%= request.city || '' %>">
                </div>
              </div>

              <div class="form-row">
                <div class="form-field">
                  <label>Owner</label>
                  <input type="text" value="<%= request.owner && request.owner.name ? request.owner.name : '' %>" disabled>
                </div>
                <div class="form-field">
                  <label for="status">Status</label>
                  <select id="status" name="status" required>
                    <option value="Open" <%= request.status === 'Open' ? 'selected' : '' %>>Open</option>
                    <option value="In Progress" <%= request.status === 'In Progress' ? 'selected' : '' %>>In progress</option>
                    <option value="Resolved" <%= request.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                    <option value="Closed" <%= request.status === 'Closed' ? 'selected' : '' %>>Closed</option>
                  </select>
                </div>
              </div>

              <div class="form-row">
                <div class="form-field">
                  <label for="deadline">Deadline</label>
                  <input type="date" id="deadline" name="deadline" value="<%= request.deadline ? request.deadline.toISOString().slice(0,10) : '' %>">
                </div>
                <div class="form-field">
                  <label for="nextFollowUpDate">Next Follow-up</label>
                  <input type="date" id="nextFollowUpDate" name="nextFollowUpDate" value="<%= request.nextFollowUpDate ? request.nextFollowUpDate.toISOString().slice(0,10) : '' %>">
                </div>
              </div>

              <div class="create-form-actions">
                <button type="submit">Save changes</button>
              </div>
            </form>
          </div>
        </section>
      </main>
    </div>
  </div>
</body>
</html>

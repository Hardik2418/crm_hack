<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Employee Dashboard</title>
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
  <div class="dashboard-layout">
    <aside class="sidebar">
      <a href="/employee/dashboard" class="sidebar-logo">ResolveX</a>
      <nav class="sidebar-nav">
        <a href="/employee/dashboard" class="sidebar-link sidebar-link-active">My Dashboard</a>
        <a href="/employee/create" class="sidebar-link">Create Request</a>
        <a href="/notifications" class="sidebar-link">Notifications</a>
      </nav>
    </aside>

    <div class="dashboard-main">
      <header class="top-navbar">
        <div class="top-navbar-left">
          <h1>Welcome, <%= user.name %></h1>
          <% if (user && user.role) { %>
            <p class="navbar-role"><%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %></p>
          <% } %>
        </div>
        <div class="top-navbar-right">
          <div class="notification-button">
            <a href="/notifications" class="btn">Notifications <sup class="notification-count"><%= unreadNotificationCount %></sup></a>
          </div>
          <a href="/logout">Logout</a>
        </div>
      </header>

      <main>
        <section class="client-top-row">
          <div class="client-welcome">
            <h2>My leads</h2>
            <p>View all your assigned leads and their status.</p>
          </div>
          <div class="client-quick-actions">
            <a href="/employee/dashboard" class="quick-action-btn">Total (all)</a>
            <a href="/employee/dashboard?status=Open" class="quick-action-btn">Open</a>
            <a href="/employee/dashboard?status=In%20Progress" class="quick-action-btn">In progress</a>
            <a href="/employee/dashboard?status=Completed" class="quick-action-btn">Completed</a>
          </div>
        </section>

        <section class="stats-grid">
          <div class="stat-card stat-card-total">
            <p class="stat-label">My Total Leads</p>
            <p class="stat-value"><%= stats.total %></p>
          </div>
          <div class="stat-card stat-card-open">
            <p class="stat-label">Open</p>
            <p class="stat-value"><%= stats.open %></p>
          </div>
          <div class="stat-card stat-card-in-progress">
            <p class="stat-label">In Progress</p>
            <p class="stat-value"><%= stats.inProgress %></p>
          </div>
          <div class="stat-card stat-card-completed">
            <p class="stat-label">Completed</p>
            <p class="stat-value"><%= stats.completed %></p>
          </div>
        </section>

        <section class="chart-section">
          <div class="chart-header">
            <h2>My requests overview</h2>
            <p class="chart-subtitle">Distribution of your open, in-progress, and completed leads.</p>
          </div>
          <div class="chart-placeholder">
            <canvas id="employeeRequestsChart"></canvas>
          </div>
        </section>

        <div class="requests-table" style="margin-top:24px;">
          <table>
            <thead>
              <tr>
                <th>Order ID</th>
                <th>Customer</th>
                <th>Product</th>
                <th>City</th>
                <th>Next Follow-up</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% requests.forEach(request => { %>
                <tr>
                  <td><%= request.orderId || request.id %></td>
                  <td><%= request.customerName || request.name %></td>
                  <td><%= request.product || '-' %></td>
                  <td><%= request.city || '-' %></td>
                  <td><%= request.nextFollowUpDate ? request.nextFollowUpDate.toISOString().slice(0, 10) : '' %></td>
                  <td><span class="status-pill status-<%= request.status.toLowerCase().replace(' ', '-') %>"><%= request.status %></span></td>
                  <td>
                    <div class="action-icons">
                      <a href="/employee/<%= request._id %>/edit">
                        <svg fill="#fff" width="20" height="20" viewBox="0 0 494.94 494.94" xmlns="http://www.w3.org/2000/svg" stroke="#fff">
                          <g>
                            <path d="M389.844,182.85c-6.743,0-12.21,5.467-12.21,12.21v222.968c0,23.562-19.174,42.735-42.736,42.735H67.157 c-23.562,0-42.736-19.174-42.736-42.735V150.285c0-23.562,19.174-42.735,42.736-42.735h267.741c6.743,0,12.21-5.467,12.21-12.21 s-5.467-12.21-12.21-12.21H67.157C30.126,83.13,0,113.255,0,150.285v267.743c0,37.029,30.126,67.155,67.157,67.155h267.741 c37.03,0,67.156-30.126,67.156-67.155V195.061C402.054,188.318,396.587,182.85,389.844,182.85z"/>
                            <path d="M483.876,20.791c-14.72-14.72-38.669-14.714-53.377,0L221.352,229.944c-0.28,0.28-3.434,3.559-4.251,5.396l-28.963,65.069 c-2.057,4.619-1.056,10.027,2.521,13.6c2.337,2.336,5.461,3.576,8.639,3.576c1.675,0,3.362-0.346,4.96-1.057l65.07-28.963 c1.83-0.815,5.114-3.97,5.396-4.25L483.876,74.169c7.131-7.131,11.06-16.61,11.06-26.692 C494.936,37.396,491.007,27.915,483.876,20.791z M466.61,56.897L257.457,266.05c-0.035,0.036-0.055,0.078-0.089,0.107 l-33.989,15.131L238.51,247.3c0.03-0.036,0.071-0.055,0.107-0.09L447.765,38.058c5.038-5.039,13.819-5.033,18.846,0.005 c2.518,2.51,3.905,5.855,3.905,9.414C470.516,51.036,469.127,54.38,466.61,56.897z"/>
                          </g>
                        </svg>
                      </a>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <section class="followup-buckets" style="margin-top:24px;">
          <h2 style="margin-bottom:12px;">My Follow-ups</h2>
          <div class="followup-grid">
            <div class="followup-column">
              <h3>Overdue</h3>
              <ul>
                <% overdueLeads.forEach(lead => { %>
                  <li>
                    <strong><%= lead.orderId || lead.id %></strong> - <%= lead.customerName || lead.name %>
                    <span class="pill pill-danger"><%= lead.nextFollowUpDate ? lead.nextFollowUpDate.toISOString().slice(0,10) : '' %></span>
                  </li>
                <% }); %>
                <% if (overdueLeads.length === 0) { %>
                  <li class="empty">No overdue follow-ups.</li>
                <% } %>
              </ul>
            </div>
            <div class="followup-column">
              <h3>Today</h3>
              <ul>
                <% todayLeads.forEach(lead => { %>
                  <li>
                    <strong><%= lead.orderId || lead.id %></strong> - <%= lead.customerName || lead.name %>
                    <span class="pill pill-warning"><%= lead.nextFollowUpDate ? lead.nextFollowUpDate.toISOString().slice(0,10) : '' %></span>
                  </li>
                <% }); %>
                <% if (todayLeads.length === 0) { %>
                  <li class="empty">No follow-ups for today.</li>
                <% } %>
              </ul>
            </div>
            <div class="followup-column">
              <h3>Upcoming (7 days)</h3>
              <ul>
                <% upcomingLeads.forEach(lead => { %>
                  <li>
                    <strong><%= lead.orderId || lead.id %></strong> - <%= lead.customerName || lead.name %>
                    <span class="pill pill-info"><%= lead.nextFollowUpDate ? lead.nextFollowUpDate.toISOString().slice(0,10) : '' %></span>
                  </li>
                <% }); %>
                <% if (upcomingLeads.length === 0) { %>
                  <li class="empty">No upcoming follow-ups.</li>
                <% } %>
              </ul>
            </div>
          </div>
        </section>
      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script defer>
    const employeeStats = <%- JSON.stringify(stats) %>;

    document.addEventListener('DOMContentLoaded', () => {
      const ctx = document.getElementById('employeeRequestsChart');
      if (ctx && window.Chart) {
        new Chart(ctx, {
          type: 'bar',
          data: {
            labels: ['Open', 'In Progress', 'Completed', 'Overdue'],
            datasets: [
              {
                label: 'My requests',
                data: [employeeStats.open, employeeStats.inProgress, employeeStats.completed, employeeStats.overdue],
                backgroundColor: [
                  'rgba(250, 204, 21, 0.8)',
                  'rgba(59, 130, 246, 0.8)',
                  'rgba(34, 197, 94, 0.8)',
                  'rgba(248, 113, 113, 0.9)'
                ],
                borderRadius: 8,
              },
            ],
          },
          options: {
            responsive: true,
            plugins: {
              legend: { display: false },
            },
            scales: {
              x: {
                ticks: { color: 'hsla(0, 0%, 100%, .7)' },
                grid: { display: false },
              },
              y: {
                ticks: { color: 'hsla(0, 0%, 100%, .5)' },
                grid: { color: 'hsla(0, 0%, 100%, .06)' },
                beginAtZero: true,
              },
            },
          },
        });
      }
    });
  </script>
</body>
</html>
